{
  "name": "@midpoker/email",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "exports": {
    "./emails/*": "./emails/*.tsx",
    "./locales": "./locales/index.ts",
    "./render": "./render.ts"
  },
  "scripts": {
    "clean": "rm -rf .turbo node_modules",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "dev": "email dev -p 3003",
    "build": "echo 'Email templates do not need build'",
    "start": "email start"
  },
  "dependencies": {
    "@midpoker/ui": "workspace:*",
    "@midpoker/utils": "workspace:*",
    "@react-email/components": "1.0.1",
    "@react-email/render": "2.0.0",
    "@react-email/tailwind": "2.0.1",
    "date-fns": "^4.1.0",
    "react-email": "5.0.4",
    "responsive-react-email": "^0.0.5"
  },
  "devDependencies": {
    "@react-email/preview-server": "5.0.4",
    "typescript": "^5.9.3",
    "@midpoker/tsconfig": "workspace:*"
  }
}
