{
  "name": "mid-poker",
  "private": true,
  "workspaces": ["packages/*", "apps/*", "packages/email/*"],
  "scripts": {
    "build": "turbo build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo clean",
    "dev": "kill $(lsof -i :3100 -t) 2>/dev/null; kill $(lsof -i :3101 -t) 2>/dev/null; kill $(lsof -i :3102 -t) 2>/dev/null; kill $(lsof -i :18790 -t) 2>/dev/null; sleep 1; redis-server --port 6380 --daemonize yes 2>/dev/null; (if [ -d ./Ppfichas ]; then cd ./Ppfichas && python3 -m uvicorn pppoker_api_server:app --host 0.0.0.0 --port 3102 & elif [ -d /Users/macosx/Ppfichas ]; then cd /Users/macosx/Ppfichas && python3 -m uvicorn pppoker_api_server:app --host 0.0.0.0 --port 3102 & else echo '[dev] PPPoker bridge nao encontrado. Continuando sem bridge.'; fi); turbo dev --filter=@midpoker/dashboard --filter=@midpoker/api --filter=@midpoker/nanobot --parallel",
    "test": "turbo test --parallel",
    "start:dashboard": "turbo start --filter=@midpoker/dashboard",
    "dev:api": "turbo dev --filter=@midpoker/api",
    "dev:dashboard": "turbo dev --filter=@midpoker/dashboard",
    "dev:nanobot": "turbo dev --filter=@midpoker/nanobot",
    "build:dashboard": "turbo build --filter=@midpoker/dashboard",
    "jobs:dashboard": "turbo jobs --filter=@midpoker/jobs",
    "format": "biome format --write .",
    "lint": "turbo lint && manypkg check",
    "typecheck": "turbo typecheck --concurrency=1"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.42",
    "@ai-sdk/openai": "^2.0.71",
    "@ai-sdk/react": "^2.0.101",
    "@ai-sdk/rsc": "^1.0.102",
    "@biomejs/biome": "1.9.4",
    "@manypkg/cli": "^0.25.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-email/preview-server": "5.0.4",
    "@supabase/postgrest-js": "^2.84.0",
    "@supabase/supabase-js": "^2.84.0",
    "@trigger.dev/react-hooks": "^4.1.2",
    "@trigger.dev/sdk": "^4.1.2",
    "@trpc/client": "^11.7.2",
    "@trpc/server": "^11.7.2",
    "@trpc/tanstack-react-query": "^11.7.2",
    "@types/react": "^19.2.7",
    "@zip.js/zip.js": "^2.8.11",
    "ai": "^5.0.101",
    "autoprefixer": "^10.4.22",
    "jspdf": "^3.0.4",
    "lucide-react": "^0.562.0",
    "next": "^16.0.4",
    "react-day-picker": "^9.11.2",
    "react-email": "5.0.4",
    "redis": "^5.10.0",
    "trigger.dev": "^4.1.2",
    "turbo": "2.6.1",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "zod": "^4.1.13"
  },
  "packageManager": "bun@1.2.22",
  "devDependencies": {
    "@types/react-syntax-highlighter": "^15.5.13"
  }
}
