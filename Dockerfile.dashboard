FROM oven/bun:1.2.22

WORKDIR /app

# Copy everything
COPY . .

# Install dependencies
RUN bun install

# Build the dashboard
RUN bun run --filter=@midpoker/dashboard build

# Expose port
EXPOSE 3000

# Set environment
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV NODE_ENV=production

# Start the dashboard
CMD ["bun", "run", "--filter=@midpoker/dashboard", "start"]
